rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if document belongs to current user
    function isOwner() {
      return resource.data.user_id == request.auth.uid;
    }

    // Helper: check if user is in same household
    function isHouseholdMember(householdId) {
      return exists(/databases/$(database)/documents/household_members/$(request.auth.uid + '_' + householdId));
    }

    // Uploads: owner only
    match /uploads/{uploadId} {
      allow read, write: if isAuth() && (
        request.auth.uid == resource.data.user_id ||
        request.auth.uid == request.resource.data.user_id
      );
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
    }

    // Transactions: owner full access, household members read-only
    match /transactions/{txId} {
      allow read: if isAuth() && (
        resource.data.user_id == request.auth.uid
      );
      allow write: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        request.resource.data.user_id == request.auth.uid
      );
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
    }

    // Budgets: owner only
    match /budgets/{budgetId} {
      allow read, write: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        request.resource.data.user_id == request.auth.uid
      );
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
    }

    // User Rules: owner only
    match /user_rules/{ruleId} {
      allow read, write: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        request.resource.data.user_id == request.auth.uid
      );
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
    }

    // Households
    match /households/{householdId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.created_by == request.auth.uid;
      allow delete: if isAuth() && resource.data.created_by == request.auth.uid;
    }

    // Household Members
    match /household_members/{memberId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuth() && resource.data.user_id == request.auth.uid;
    }

    // Household Invites
    match /household_invites/{inviteId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.invited_by == request.auth.uid;
      allow update: if isAuth();
      allow delete: if isAuth() && resource.data.invited_by == request.auth.uid;
    }

    // Household Visibility
    match /household_visibility/{visId} {
      allow read: if isAuth();
      allow write: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        request.resource.data.user_id == request.auth.uid
      );
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
    }
  }
}
